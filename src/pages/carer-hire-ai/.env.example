# ── Frontend (Vite) ────────────────────────────────────────────────────────────
# Stripe publishable key (safe to expose in browser)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase public credentials (safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Backend / Serverless API functions ─────────────────────────────────────────
# Anthropic API key — server-side ONLY (used by api/chat.js). NEVER use VITE_ prefix here.
ANTHROPIC_API_KEY=sk-ant-...

# Stripe secret key (NEVER expose client-side)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (from Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase service-role key (NEVER expose client-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
